class Solution {
public:
    int maxPathSum(TreeNode* root) {
        int maxi = INT_MIN;
        maxpath(root, maxi);
        return maxi;
    }
    int maxpath(TreeNode* root, int& maxi) {
        if (root == NULL)
            return 0;
        int lh = max(0, maxpath(root->left, maxi));
        int rh = max(0, maxpath(root->right, maxi));
        maxi = max(maxi, lh + rh + root->val);
        return max(lh, rh) + root->val;
    }
};
